rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'ADMIN';
    }
    function isInstructor() {
      return isAuthenticated() && request.auth.token.role in ['ADMIN', 'INSTRUCTOR'];
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /sessions/{sessionId} {
      allow create: if isAuthenticated();
      allow read:   if isAuthenticated() &&
        (resource.data.studentId == request.auth.uid || isInstructor());
      allow update: if isAuthenticated() &&
        (resource.data.studentId == request.auth.uid || isInstructor());
      allow delete: if isInstructor();

      match /compressions/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /alerts/{docId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /courses/{courseId} {
      allow read:   if isAuthenticated();
      allow create: if isInstructor();
      allow update: if isInstructor();
      allow delete: if isAdmin();

      match /enrollments/{enrollmentId} {
        allow read:   if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isInstructor();
        allow delete: if isInstructor();
      }
    }

    match /manikins/{manikinId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    match /scenarios/{scenarioId} {
      allow read:  if isAuthenticated();
      allow write: if isInstructor();
    }
  }
}
